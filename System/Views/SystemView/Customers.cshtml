@{
    Layout = "~/Views/Shared/_LayoutForContent.cshtml";
}
<div class="fixed w-1/4 bg-[var(--primary)] h-[100%] top-0 z-10 sideBarContainer" style="animation: SlideLeft 1s ease-in-out" id="sidebar">
    <div class="flex flex-col gap-8 text-lg font-semibold text-[var(--bg)] m-12">
        <div class="flex gap-1 mt-10 cursor-pointer"  ng-click="redirectFunc('Dashboard')">
            <i class="fa-solid fa-chart-area mt-2"></i>
            <p class="mt-1">DashBoard</p>
        </div>
        <div class="flex gap-1 cursor-pointer" >
            <i class="fa-regular fa-circle-user mt-2"></i>
            <p class="mt-1">Customers</p>
        </div>
        <div class="flex gap-1 cursor-pointer" ng-click="redirectFunc('Orders')">
            <i class="fa-solid fa-receipt mt-2"></i>
            <p>Orders</p>
        </div>
        <div class="flex gap-1 cursor-pointer" ng-click="redirectFunc('Reports')">
            <i class="fa-solid fa-newspaper mt-2"></i>
            <p class="mt-1">Reports</p>
        </div>
        <div class="flex gap-1 cursor-pointer" ng-click="redirectFunc('Index')">
            <i class="fa-solid fa-door-open mt-2"></i>
            <p class="mt-1">Signout </p>
        </div>
    </div>
</div>
<div ng-init="getUsersDataFunc()" class="mainContainer">
    <div class="min-h-screen flex items-center justify-center text-white">
        <div class="w-full max-w-[90%] p-8">
            <h1 class="text-3xl font-bold mb-4 text-[var(--text)]">
                Add <span class="text-[var(--primary)]">Customers</span>
            </h1>
            <div class="flex flex-col gap-8 mb-8">
                <form class="flex flex-wrap p-4 border border-transparent rounded-md">
                    <div class="flex w-1/2 flex-col p-2">
                        <div class="flex justify-between"><label for="Name" class="text-sm text-[var(--text-sub)] font-bold">Name: <span class="text-[#ff7276] text-md">*</span></label> <span class="text-[#ff7276] text-sm" ng-show="NameField">Please fill this field</span></div>
                        <input type="text"
                               class="validate rounded-md bg-[var(--border)] border-[1.5px] border-[var(--border)] p-3 focus:outline-none  focus:border-[var(--primary)] focus:bg-[var(--bg)] text-black"
                               placeholder="Juan Dela Cruz"
                               maxlength="70"
                               ng-model="Name" required />

                    </div>

                    <div class="flex w-1/2 flex-col p-2">
                        <div class="flex justify-between"><label for="Name" class="text-sm text-[var(--text-sub)] font-bold">Contact: <span class="text-[#ff7276] text-md">*</span></label> <span class="text-[#ff7276] text-sm" ng-show="ContactField">Please fill this field</span></div>
                        <input type="text"
                               class="validate rounded-md bg-[var(--border)] border-[1.5px] border-[var(--border)] p-3 focus:outline-none  focus:border-[var(--primary)] focus:bg-[var(--bg)] text-black"
                               placeholder="9272413924"
                               maxlength="12"
                               ng-model="Contact" required />
                    </div>
                    <div class="flex w-1/2 flex-col p-2">
                        <div class="flex justify-between"><label for="Name" class="text-sm  text-[var(--text-sub)] font-bold">Username: <span class="text-[#ff7276] text-md">*</span></label> <span class="text-[#ff7276] text-sm" ng-show="UsernameField">Please fill this field</span></div>
                        <input type="text"
                               class="validate rounded-md bg-[var(--border)] border-[1.5px] border-[var(--border)] p-3 focus:outline-none  focus:border-[var(--primary)] focus:bg-[var(--bg)] text-black"
                               placeholder="juan@gmail.com"
                               maxlength="25"
                               ng-model="Username" required />
                    </div>
                    <div class="flex w-1/2 flex-col p-2">
                        <div class="flex justify-between"><label for="Name" class="text-sm text-[var(--text-sub)] font-bold">Password: <span class="text-[#ff7276] text-md">*</span></label> <span class="text-[#ff7276] text-sm" ng-show="PasswordField">Please fill this field</span></div>
                        <input type="text"
                               class="validate  rounded-md bg-[var(--border)] border-[1.5px] border-[var() p-3 focus:outline-none  focus:border-[var(--primary)] focus:bg-[var(--bg)] text-black"
                               placeholder="juan123"
                               maxlength="25"
                               ng-model="Password" required />
                    </div>
                    <div class="flex w-full flex-col p-2">
                        <label for="Name" class="text-sm  text-[var(--text-sub)] font-bold">Address:</label>
                        <input type="text"
                               class="validate rounded-md bg-[var(--border)] border-[1.5px] border-[var--border)] p-3 focus:outline-none  focus:border-[var(--primary)] focus:bg-[var(--bg)] text-black"
                               placeholder="San Juan Manila"
                               maxlength="30"
                               ng-model="Address" required />
                    </div>
                </form>

                <div class="flex flex-col gap-2">
                    <input type="submit"
                           ng-click="saveUserFunc()"
                           value="Add"
                           class="rounded-full bg-[var(--primary)] border border-transparent p-3 transform hover:scale-105 transistion duration-300 text-white font-bold" />
                    <input type="submit"
                           ng-click="removeFunction()"
                           value="Clear"
                           class="rounded-full bg-[#FF0000] border border-transparent p-3 transform hover:scale-105 transistion duration-300 text-black font-bold" />
                    
                </div>
            </div>
            <div class="rounded-tl-full rounded-tr-full p-2 bg-white border-t-[3.5px] border-[var(--border)] text-[var(--primary)] w-[20%]">
                <div class="flex justify-center align-center mt-2">
                    <i class="fa-solid fa-circle-user text-3xl align-center "></i>
                    <p ng-show="isWeb" class="text-2xl font-bold">List</p>
                </div>
            </div>
            <div class="flex flex-col items-center gap-1">
                <div class="rounded-md bg-white border border-transparent w-full">
                    <div class="m-8">
                        <div ng-repeat="user in userDatas" class="transform hover:scale-105 transition duration-700 cursor-pointer">
                            <div class="border-b-[2.5px] border-[var(--border)] rounded-full font-bold flex p-2">
                                <div class="bg-[var(--border)] rounded-full text-[var(--primary)] p-4">
                                    <i class="fa-regular fa-face-grin m-[auto]"></i>
                                </div>
                                <div class="flex justify-between w-full">
                                    <div class="flex flex-col gap-1 ml-2 text-[var(--text)]">
                                        <p class="text-xl font-small">{{user.Name}}</p>
                                        <div class="flex gap-2" ng-show="isWeb">
                                            <p class="text-sm text-[var(--primary)]">{{user.Address}}</p>
                                            <p class="mb-1">•</p>
                                            <p class="text-sm font-sm">{{user.Contact}}</p>
                                        </div>

                                    </div>
                                   
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
